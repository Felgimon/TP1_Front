---
// PlayerSearch.astro — Buscador de jugadores con resultados
---

<div class="tab-content" id="tab-players">
	<div class="search-bar">
		<svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
			<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
		</svg>
		<input
			type="text"
			id="player-search"
			placeholder="Search a player... (e.g. LeBron James)"
			autocomplete="off"
		/>
	</div>
	<div id="player-results"></div>
</div>

<style>
	.tab-content {
		display: none;
	}

	.tab-content.active {
		display: block;
	}

	.search-bar {
		position: relative;
		margin-bottom: 1vw;
	}

	.search-icon {
		position: absolute;
		left: 1vw;
		top: 50%;
		transform: translateY(-50%);
		width: 1.1vw;
		height: 1.1vw;
		min-width: 16px;
		min-height: 16px;
		color: var(--cs-text-hint);
	}

	.search-bar input {
		width: 100%;
		padding: 0.7vw 1vw 0.7vw 2.8vw;
		background: var(--cs-input-bg);
		border: 0.5px solid var(--cs-input-border);
		border-radius: 0.6vw;
		color: var(--cs-text-primary);
		font-size: 0.85vw;
		font-family: inherit;
		outline: none;
		transition: border-color 0.2s ease, background 0.3s ease;
	}

	.search-bar input::placeholder {
		color: var(--cs-text-hint);
	}

	.search-bar input:focus {
		border-color: var(--cs-input-focus);
	}
</style>
