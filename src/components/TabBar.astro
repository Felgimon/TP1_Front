---
// TabBar.astro — Toggle entre las dos secciones principales
---

<div class="tabs">
	<button class="tab active" data-tab="games">Today's games</button>
	<button class="tab" data-tab="players">Search players</button>
</div>

<style>
	.tabs {
		display: flex;
		gap: 0;
		background: var(--cs-card-bg);
		border-radius: 0.6vw;
		overflow: hidden;
		border: 0.5px solid var(--cs-border);
		flex-shrink: 0;
		transition: background 0.3s ease, border-color 0.3s ease;
	}

	.tab {
		flex: 1;
		padding: 0.7vw 1vw;
		text-align: center;
		font-size: 0.85vw;
		font-weight: 500;
		color: var(--cs-text-muted);
		background: none;
		border: none;
		cursor: pointer;
		transition: all 0.2s ease;
		font-family: inherit;
	}

	.tab:hover {
		color: var(--cs-text-secondary);
	}

	.tab.active {
		color: var(--cs-text-primary);
		background: var(--cs-accent-bg);
		border-bottom: 2px solid var(--cs-accent);
	}
</style>
