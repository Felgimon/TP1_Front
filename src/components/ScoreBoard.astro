---
// ScoreBoard.astro
// Componente orquestador del dashboard NBA.
// Importa sub-componentes presentacionales y maneja toda la lógica client-side.
import TabBar from './TabBar.astro';
import GamesGrid from './GamesGrid.astro';
import PlayerSearch from './PlayerSearch.astro';
import PlayerSpotlight from './PlayerSpotlight.astro';
import ApiKeyBar from './ApiKeyBar.astro';
---

<section class="scoreboard">
	<TabBar />
	<GamesGrid />
	<PlayerSearch />
	<PlayerSpotlight />
	<ApiKeyBar />
</section>

<script>
// ==========================================================
//  COURTSIDE — NBA SCOREBOARD CLIENT
// ==========================================================

const API_BASE = 'https://api.balldontlie.io/nba/v1';
const STORAGE_KEY = 'courtside_api_key';

// ---- State ----
let apiKey = localStorage.getItem(STORAGE_KEY) || '';
let searchTimeout: ReturnType<typeof setTimeout> | null = null;

// ---- Rate limit queue (free tier = 5 req/min) ----
const REQUEST_GAP_MS = 1500; // 1.5s entre requests → máx 40/min, bien dentro del límite
let lastRequestTime = 0;

async function rateLimitedFetch(url: string): Promise<Response> {
	const now = Date.now();
	const wait = Math.max(0, REQUEST_GAP_MS - (now - lastRequestTime));
	if (wait > 0) await new Promise(r => setTimeout(r, wait));
	lastRequestTime = Date.now();
	return fetch(url, { headers: { 'Authorization': apiKey } });
}

// ---- DOM refs ----
const tabs = document.querySelectorAll('.tab') as NodeListOf<HTMLButtonElement>;
const tabGames = document.getElementById('tab-games') as HTMLElement;
const tabPlayers = document.getElementById('tab-players') as HTMLElement;
const gamesGrid = document.getElementById('games-grid') as HTMLElement;
const playerSearch = document.getElementById('player-search') as HTMLInputElement;
const playerResults = document.getElementById('player-results') as HTMLElement;
const spotlight = document.getElementById('spotlight') as HTMLElement;
const spotlightCard = document.getElementById('spotlight-card') as HTMLElement;
const apiKeyInput = document.getElementById('api-key-input') as HTMLInputElement;
const apiKeySave = document.getElementById('api-key-save') as HTMLButtonElement;

// ---- API helper (con rate limit) ----
async function apiFetch(endpoint: string): Promise<any> {
	const res = await rateLimitedFetch(`${API_BASE}${endpoint}`);
	if (res.status === 429) throw new Error('RATE_LIMIT');
	if (!res.ok) throw new Error(`API ${res.status}`);
	return res.json();
}

// ---- TABS ----
tabs.forEach(tab => {
	tab.addEventListener('click', () => {
		tabs.forEach(t => t.classList.remove('active'));
		tab.classList.add('active');

		const target = tab.dataset.tab;
		tabGames.classList.toggle('active', target === 'games');
		tabPlayers.classList.toggle('active', target === 'players');
		spotlight.style.display = target === 'games' ? '' : 'none';
	});
});

// ---- FORMAT helpers ----
function getTeamAbbr(team: any): string {
	return team.abbreviation || team.name?.substring(0, 3).toUpperCase() || '???';
}

function formatGameStatus(game: any): { label: string; detail: string; class: string } {
	const status = game.status;

	// Final
	if (status === 'Final') {
		return { label: 'FINAL', detail: 'FT', class: 'status-final' };
	}

	// Upcoming: status es un timestamp ISO (ej: "2025-03-21T23:00:00Z")
	// Se detecta porque parsea como fecha válida y tiene formato ISO
	if (status && /^\d{4}-\d{2}-\d{2}T/.test(status)) {
		const date = new Date(status);
		const timeStr = !isNaN(date.getTime())
			? date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true })
			: 'TBD';
		return { label: 'UPCOMING', detail: timeStr, class: 'status-upcoming' };
	}

	// In Progress / cualquier otro status con periodo activo → LIVE
	if (status === 'In Progress' || (game.period && game.period > 0)) {
		return { label: 'LIVE', detail: game.period ? `Q${game.period} ${game.time || ''}`.trim() : '', class: 'status-live' };
	}

	// Fallback
	return { label: 'UPCOMING', detail: status || 'TBD', class: 'status-upcoming' };
}

// ---- RENDER: Game card ----
function renderGameCard(game: any): string {
	const home = game.home_team;
	const visitor = game.visitor_team;
	const homeScore = game.home_team_score;
	const visitorScore = game.visitor_team_score;
	const { label, detail, class: statusClass } = formatGameStatus(game);

	const isFinal = label === 'FINAL';
	const isUpcoming = label === 'UPCOMING';
	const homeWins = isFinal && homeScore > visitorScore;
	const visitorWins = isFinal && visitorScore > homeScore;

	if (isUpcoming) {
		return `
		<div class="game-card">
			<div class="game-header">
				<span class="game-status ${statusClass}">${label}</span>
				<span class="game-detail">${detail}</span>
			</div>
			<div class="game-matchup-upcoming">
				<div class="team-center">
					<div class="team-badge">${getTeamAbbr(visitor)}</div>
					<span class="team-name">${visitor.full_name || visitor.name}</span>
				</div>
				<span class="vs-label">VS</span>
				<div class="team-center">
					<div class="team-badge">${getTeamAbbr(home)}</div>
					<span class="team-name">${home.full_name || home.name}</span>
				</div>
			</div>
		</div>`;
	}

	return `
	<div class="game-card">
		<div class="game-header">
			<span class="game-status ${statusClass}">${label}</span>
			<span class="game-detail ${statusClass === 'status-live' ? 'detail-live' : ''}">${detail}</span>
		</div>
		<div class="game-row">
			<div class="team-info">
				<div class="team-badge">${getTeamAbbr(visitor)}</div>
				<span class="team-name">${visitor.full_name || visitor.name}</span>
			</div>
			<span class="score ${visitorWins ? 'score-winner' : ''}">${visitorScore ?? '-'}</span>
		</div>
		<div class="game-row">
			<div class="team-info">
				<div class="team-badge">${getTeamAbbr(home)}</div>
				<span class="team-name">${home.full_name || home.name}</span>
			</div>
			<span class="score ${homeWins ? 'score-winner' : ''}">${homeScore ?? '-'}</span>
		</div>
	</div>`;
}

// ---- RENDER: Player stat card ----
function renderPlayerCard(player: any, stats: any): string {
	const initials = `${(player.first_name || '?')[0]}${(player.last_name || '?')[0]}`;
	const name = `${player.first_name} ${player.last_name}`;
	const team = player.team?.full_name || 'Free Agent';
	const number = player.jersey_number ? `  |  #${player.jersey_number}` : '';
	const position = player.position ? `  |  ${player.position}` : '';

	const pts = stats?.pts?.toFixed(1) ?? '--';
	const reb = stats?.reb?.toFixed(1) ?? '--';
	const ast = stats?.ast?.toFixed(1) ?? '--';
	const fg = stats?.fg_pct != null ? (stats.fg_pct * 100).toFixed(1) : '--';

	return `
	<div class="player-card">
		<div class="player-header">
			<div class="player-avatar">${initials}</div>
			<div>
				<div class="player-name">${name}</div>
				<div class="player-meta">${team}${number}${position}</div>
			</div>
		</div>
		<div class="stats-grid">
			<div class="stat-box">
				<div class="stat-label">PTS</div>
				<div class="stat-value">${pts}</div>
			</div>
			<div class="stat-box">
				<div class="stat-label">REB</div>
				<div class="stat-value">${reb}</div>
			</div>
			<div class="stat-box">
				<div class="stat-label">AST</div>
				<div class="stat-value">${ast}</div>
			</div>
			<div class="stat-box">
				<div class="stat-label">FG%</div>
				<div class="stat-value accent">${fg}</div>
			</div>
		</div>
	</div>`;
}

// ---- FETCH: Today's games ----
async function loadGames() {
	if (!apiKey) {
		gamesGrid.innerHTML = '<div class="empty-state">Enter your API key below to load games</div>';
		return;
	}
	try {
		const today = new Date().toISOString().split('T')[0];
		const data = await apiFetch(`/games?dates[]=${today}`);
		const games = data.data || [];
		if (games.length === 0) {
			gamesGrid.innerHTML = '<div class="empty-state">No games scheduled today</div>';
			return;
		}
		gamesGrid.innerHTML = games.map(renderGameCard).join('');
	} catch (err: any) {
		const msg = err?.message === 'RATE_LIMIT'
			? 'Rate limit reached (5 req/min on free tier). Wait a moment and reload.'
			: 'Failed to load games. Check your API key.';
		gamesGrid.innerHTML = `<div class="empty-state error">${msg}</div>`;
	}
}

// ---- FETCH: Player spotlight ----
async function loadSpotlight() {
	if (!apiKey) {
		spotlightCard.innerHTML = '<div class="empty-state small">Enter API key to see spotlight</div>';
		return;
	}
	try {
		const featuredPlayers = ['LeBron James', 'Stephen Curry', 'Nikola Jokic', 'Luka Doncic', 'Giannis Antetokounmpo', 'Jayson Tatum', 'Anthony Edwards', 'Victor Wembanyama'];
		const pick = featuredPlayers[Math.floor(Math.random() * featuredPlayers.length)];
		const searchData = await apiFetch(`/players?search=${encodeURIComponent(pick)}&per_page=1`);
		const player = searchData.data?.[0];
		if (!player) {
			spotlightCard.innerHTML = '<div class="empty-state small">No player found</div>';
			return;
		}
		const currentYear = new Date().getFullYear();
		const season = new Date().getMonth() >= 9 ? currentYear : currentYear - 1;
		let stats = null;
		try {
			const statsData = await apiFetch(`/season_averages?season=${season}&player_ids[]=${player.id}`);
			stats = statsData.data?.[0] || null;
		} catch { /* stats optional */ }
		spotlightCard.innerHTML = renderPlayerCard(player, stats);
	} catch {
		spotlightCard.innerHTML = '<div class="empty-state small">Could not load spotlight</div>';
	}
}

// ---- FETCH: Search players ----
async function searchPlayers(query: string) {
	if (!apiKey) {
		playerResults.innerHTML = '<div class="empty-state">Enter your API key below to search</div>';
		return;
	}
	if (query.length < 2) {
		playerResults.innerHTML = '<div class="empty-state">Type at least 2 characters</div>';
		return;
	}
	playerResults.innerHTML = '<div class="loading"><div class="spinner"></div><span>Searching...</span></div>';
	try {
		const data = await apiFetch(`/players?search=${encodeURIComponent(query)}&per_page=5`);
		const players = data.data || [];
		if (players.length === 0) {
			playerResults.innerHTML = '<div class="empty-state">No players found</div>';
			return;
		}
		const currentYear = new Date().getFullYear();
		const season = new Date().getMonth() >= 9 ? currentYear : currentYear - 1;
		const ids = players.map((p: any) => `player_ids[]=${p.id}`).join('&');
		let statsMap: Record<number, any> = {};
		try {
			const statsData = await apiFetch(`/season_averages?season=${season}&${ids}`);
			for (const s of (statsData.data || [])) {
				statsMap[s.player_id] = s;
			}
		} catch { /* stats optional */ }
		playerResults.innerHTML = players
			.map((p: any) => renderPlayerCard(p, statsMap[p.id] || null))
			.join('');
	} catch (err: any) {
		const msg = err?.message === 'RATE_LIMIT'
			? 'Rate limit reached. Wait a moment and try again.'
			: 'Search failed. Check your API key.';
		playerResults.innerHTML = `<div class="empty-state error">${msg}</div>`;
	}
}

// ---- Search debounce ----
playerSearch.addEventListener('input', () => {
	if (searchTimeout) clearTimeout(searchTimeout);
	searchTimeout = setTimeout(() => {
		searchPlayers(playerSearch.value.trim());
	}, 800);
});

// ---- API Key ----
if (apiKey) {
	apiKeyInput.value = '••••••••••••';
	apiKeySave.textContent = 'Connected';
	apiKeySave.classList.add('connected');
}

// Al hacer focus en el input, limpiar si muestra dots
apiKeyInput.addEventListener('focus', () => {
	if (apiKeyInput.value === '••••••••••••') {
		apiKeyInput.value = '';
		apiKeySave.textContent = 'Connect';
		apiKeySave.classList.remove('connected');
	}
});

// Si sale del input sin poner nada, restaurar el estado
apiKeyInput.addEventListener('blur', () => {
	if (!apiKeyInput.value.trim() && apiKey) {
		apiKeyInput.value = '••••••••••••';
		apiKeySave.textContent = 'Connected';
		apiKeySave.classList.add('connected');
	}
});

apiKeySave.addEventListener('click', async () => {
	const val = apiKeyInput.value.trim();
	if (!val || val === '••••••••••••') return;
	apiKey = val;
	localStorage.setItem(STORAGE_KEY, val);
	apiKeyInput.value = '••••••••••••';
	apiKeySave.textContent = 'Connected';
	apiKeySave.classList.add('connected');
	await loadGames();
	await loadSpotlight();
});

// ---- Init (secuencial para respetar rate limit) ----
(async () => {
	await loadGames();
	await loadSpotlight();
})();
</script>

<!-- Estilos del layout del scoreboard + estilos globales para HTML generado dinámicamente -->
<style>
	.scoreboard {
		padding: 1.5vw 4vw;
		height: 90%;
		display: flex;
		flex-direction: column;
		gap: 1.2vw;
		overflow-y: auto;
	}

	.scoreboard::-webkit-scrollbar {
		width: 4px;
	}

	.scoreboard::-webkit-scrollbar-track {
		background: transparent;
	}

	.scoreboard::-webkit-scrollbar-thumb {
		background: rgba(255,255,255,0.1);
		border-radius: 2px;
	}
</style>

<!-- Estilos globales para el HTML inyectado por JS (game cards, player cards, etc.) -->
<style is:global>
	/* Game cards */
	.game-card {
		background: rgba(255,255,255,0.04);
		border-radius: 0.7vw;
		padding: 1vw 1.2vw;
		border: 0.5px solid rgba(255,255,255,0.06);
		transition: border-color 0.2s ease;
	}

	.game-card:hover {
		border-color: rgba(255,255,255,0.12);
	}

	.game-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 0.8vw;
	}

	.game-status {
		font-size: 0.65vw;
		color: rgba(240,240,240,0.35);
		letter-spacing: 1.5px;
		font-weight: 500;
	}

	.game-detail {
		font-size: 0.6vw;
		color: rgba(240,240,240,0.25);
	}

	.detail-live {
		color: #E8450E;
		background: rgba(232,69,14,0.15);
		padding: 0.15vw 0.5vw;
		border-radius: 0.3vw;
		font-weight: 500;
	}

	.game-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.3vw 0;
	}

	.team-info {
		display: flex;
		align-items: center;
		gap: 0.5vw;
	}

	.team-badge {
		width: 2vw;
		height: 2vw;
		min-width: 28px;
		min-height: 28px;
		border-radius: 50%;
		background: rgba(255,255,255,0.08);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.6vw;
		color: rgba(240,240,240,0.5);
		font-weight: 500;
		letter-spacing: 0.5px;
	}

	.team-name {
		font-size: 0.9vw;
		color: #F0F0F0;
		font-weight: 500;
	}

	.score {
		font-size: 1.2vw;
		color: rgba(240,240,240,0.6);
		font-weight: 500;
	}

	.score-winner {
		color: #E8450E;
	}

	.game-matchup-upcoming {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.5vw;
		padding: 0.5vw 0;
	}

	.team-center {
		text-align: center;
	}

	.team-center .team-badge {
		margin: 0 auto 0.3vw;
	}

	.vs-label {
		font-size: 0.8vw;
		color: rgba(240,240,240,0.2);
		font-weight: 500;
	}

	/* Player cards */
	.player-card {
		background: rgba(255,255,255,0.04);
		border-radius: 0.7vw;
		padding: 1.2vw;
		border: 0.5px solid rgba(255,255,255,0.06);
		margin-bottom: 0.6vw;
	}

	.player-header {
		display: flex;
		align-items: center;
		gap: 0.8vw;
		margin-bottom: 1vw;
	}

	.player-avatar {
		width: 3vw;
		height: 3vw;
		min-width: 40px;
		min-height: 40px;
		border-radius: 50%;
		background: linear-gradient(135deg, #E8450E, #FF7A3D);
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 500;
		font-size: 0.85vw;
		color: #1A1A2E;
		flex-shrink: 0;
	}

	.player-name {
		font-size: 1vw;
		color: #F0F0F0;
		font-weight: 500;
	}

	.player-meta {
		font-size: 0.7vw;
		color: rgba(240,240,240,0.4);
		margin-top: 0.15vw;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.5vw;
	}

	.stat-box {
		text-align: center;
		background: rgba(255,255,255,0.03);
		border-radius: 0.5vw;
		padding: 0.7vw 0.3vw;
	}

	.stat-label {
		font-size: 0.6vw;
		color: rgba(240,240,240,0.35);
		margin-bottom: 0.3vw;
		letter-spacing: 0.5px;
	}

	.stat-value {
		font-size: 1.15vw;
		color: #F0F0F0;
		font-weight: 500;
	}

	.stat-value.accent {
		color: #E8450E;
	}

	/* Shared states */
	.loading {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6vw;
		padding: 2vw;
		color: rgba(240,240,240,0.3);
		font-size: 0.8vw;
	}

	.spinner {
		width: 1.2vw;
		height: 1.2vw;
		min-width: 16px;
		min-height: 16px;
		border: 2px solid rgba(255,255,255,0.1);
		border-top-color: #E8450E;
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
	}

	@keyframes spin {
		to { transform: rotate(360deg); }
	}

	.empty-state {
		text-align: center;
		padding: 2vw;
		color: rgba(240,240,240,0.3);
		font-size: 0.85vw;
		grid-column: 1 / -1;
	}

	.empty-state.small {
		padding: 1.2vw;
		font-size: 0.75vw;
	}

	.empty-state.error {
		color: #E24B4A;
	}
</style>