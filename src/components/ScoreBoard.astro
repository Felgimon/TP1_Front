---
// ScoreBoard.astro
// Componente orquestador del dashboard NBA.
// Consume API routes locales que hacen proxy a NBA.com (sin API key, sin rate limit).
import TabBar from './TabBar.astro';
import GamesGrid from './GamesGrid.astro';
import PlayerSearch from './PlayerSearch.astro';
import PlayerSpotlight from './PlayerSpotlight.astro';
---

<section class="scoreboard">
	<TabBar />
	<GamesGrid />
	<PlayerSearch />
	<PlayerSpotlight />
</section>

<script>
// ==========================================================
//  COURTSIDE — NBA SCOREBOARD (NBA.com proxy)
// ==========================================================

// ---- DOM refs ----
const tabs = document.querySelectorAll('.tab') as NodeListOf<HTMLButtonElement>;
const tabGames = document.getElementById('tab-games') as HTMLElement;
const tabPlayers = document.getElementById('tab-players') as HTMLElement;
const gamesGrid = document.getElementById('games-grid') as HTMLElement;
const playerSearch = document.getElementById('player-search') as HTMLInputElement;
const playerResults = document.getElementById('player-results') as HTMLElement;
const spotlight = document.getElementById('spotlight') as HTMLElement;
const spotlightCard = document.getElementById('spotlight-card') as HTMLElement;

let searchTimeout: ReturnType<typeof setTimeout> | null = null;

// ---- Fetch con reintentos (client-side) ----
async function fetchRetry(url: string, maxRetries = 3, baseDelay = 2000): Promise<Response> {
	for (let attempt = 0; attempt < maxRetries; attempt++) {
		try {
			const res = await fetch(url);
			if (res.ok) return res;
			// Si el server devolvió error, reintentamos
			if (attempt === maxRetries - 1) return res;
		} catch {
			if (attempt === maxRetries - 1) throw new Error('fetch failed');
		}
		await new Promise(r => setTimeout(r, baseDelay * (attempt + 1)));
	}
	throw new Error('fetch failed');
}

// ---- TABS ----
tabs.forEach(tab => {
	tab.addEventListener('click', () => {
		tabs.forEach(t => t.classList.remove('active'));
		tab.classList.add('active');

		const target = tab.dataset.tab;
		tabGames.classList.toggle('active', target === 'games');
		tabPlayers.classList.toggle('active', target === 'players');
		spotlight.style.display = target === 'games' ? '' : 'none';
	});
});

// ---- RENDER: Game card ----
function renderGameCard(game: any): string {
	const home = game.homeTeam;
	const away = game.awayTeam;
	const statusCode = game.statusCode; // 1=upcoming, 2=live, 3=final

	if (statusCode === 1) {
		// UPCOMING
		const startDate = new Date(game.startTime);
		const timeStr = !isNaN(startDate.getTime())
			? startDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true })
			: game.status || 'TBD';

		return `
		<div class="game-card">
			<div class="game-header">
				<span class="game-status">UPCOMING</span>
				<span class="game-detail">${timeStr}</span>
			</div>
			<div class="game-matchup-upcoming">
				<div class="team-center">
					<div class="team-badge">${away.abbr}</div>
					<span class="team-name">${away.city} ${away.name}</span>
				</div>
				<span class="vs-label">VS</span>
				<div class="team-center">
					<div class="team-badge">${home.abbr}</div>
					<span class="team-name">${home.city} ${home.name}</span>
				</div>
			</div>
		</div>`;
	}

	// LIVE or FINAL
	const isLive = statusCode === 2;
	const isFinal = statusCode === 3;
	const homeWins = isFinal && home.score > away.score;
	const awayWins = isFinal && away.score > home.score;
	const statusLabel = isLive ? 'LIVE' : 'FINAL';
	const detail = isLive
		? `Q${game.period} ${game.clock}`
		: 'FT';

	return `
	<div class="game-card">
		<div class="game-header">
			<span class="game-status">${statusLabel}</span>
			<span class="game-detail ${isLive ? 'detail-live' : ''}">${detail}</span>
		</div>
		<div class="game-row">
			<div class="team-info">
				<div class="team-badge">${away.abbr}</div>
				<span class="team-name">${away.city} ${away.name}</span>
			</div>
			<span class="score ${awayWins ? 'score-winner' : ''}">${away.score}</span>
		</div>
		<div class="game-row">
			<div class="team-info">
				<div class="team-badge">${home.abbr}</div>
				<span class="team-name">${home.city} ${home.name}</span>
			</div>
			<span class="score ${homeWins ? 'score-winner' : ''}">${home.score}</span>
		</div>
	</div>`;
}

// ---- RENDER: Player stat card ----
function renderPlayerCard(player: any): string {
	const initials = `${(player.firstName || player.name?.[0] || '?')[0]}${(player.lastName || player.name?.split(' ')[1]?.[0] || '?')[0]}`.toUpperCase();
	const name = player.name || `${player.firstName} ${player.lastName}`;
	const team = [player.teamCity, player.teamName || player.team].filter(Boolean).join(' ') || 'Free Agent';
	const number = player.jerseyNumber ? `  |  #${player.jerseyNumber}` : '';
	const position = player.position ? `  |  ${player.position}` : '';

	const s = player.seasonStats;
	const pts = s?.pts?.toFixed(1) ?? '--';
	const reb = s?.reb?.toFixed(1) ?? '--';
	const ast = s?.ast?.toFixed(1) ?? '--';
	const fg = s?.fgPct != null ? (s.fgPct * 100).toFixed(1) : '--';

	return `
	<div class="player-card">
		<div class="player-header">
			<div class="player-avatar">${initials}</div>
			<div>
				<div class="player-name">${name}</div>
				<div class="player-meta">${team}${number}${position}</div>
			</div>
		</div>
		<div class="stats-grid">
			<div class="stat-box">
				<div class="stat-label">PTS</div>
				<div class="stat-value">${pts}</div>
			</div>
			<div class="stat-box">
				<div class="stat-label">REB</div>
				<div class="stat-value">${reb}</div>
			</div>
			<div class="stat-box">
				<div class="stat-label">AST</div>
				<div class="stat-value">${ast}</div>
			</div>
			<div class="stat-box">
				<div class="stat-label">FG%</div>
				<div class="stat-value accent">${fg}</div>
			</div>
		</div>
	</div>`;
}

// ---- FETCH: Today's games ----
async function loadGames() {
	try {
		const res = await fetch('/api/scoreboard');
		const data = await res.json();
		const games = data.games || [];

		if (games.length === 0) {
			gamesGrid.innerHTML = '<div class="empty-state">No games scheduled today</div>';
			return;
		}

		gamesGrid.innerHTML = games.map(renderGameCard).join('');
	} catch {
		gamesGrid.innerHTML = '<div class="empty-state error">Failed to load games</div>';
	}
}

// ---- FETCH: Player spotlight ----
async function loadSpotlight() {
	try {
		const starNames = [
			'LeBron James', 'Stephen Curry', 'Nikola Jokic',
			'Luka Doncic', 'Giannis Antetokounmpo', 'Jayson Tatum',
			'Anthony Edwards', 'Victor Wembanyama',
		];
		const name = starNames[Math.floor(Math.random() * starNames.length)];

		spotlightCard.innerHTML = `<div class="loading"><div class="spinner"></div><span>Loading ${name}...</span></div>`;

		const searchRes = await fetch(`/api/players?search=${encodeURIComponent(name)}`);
		const searchData = await searchRes.json();
		const found = searchData.players?.[0];
		if (!found) throw new Error('Player not found');

		const res = await fetchRetry(`/api/player-stats/${found.id}`);
		const data = await res.json();

		if (data.player) {
			spotlightCard.innerHTML = renderPlayerCard(data.player);
		} else {
			spotlightCard.innerHTML = '<div class="empty-state small">Stats not available right now</div>';
		}
	} catch {
		spotlightCard.innerHTML = '<div class="empty-state small">Could not load spotlight. <button class="retry-btn" onclick="window.__retrySpotlight();">Retry</button></div>';
	}
}
// Expose retry globally for the button
(window as any).__retrySpotlight = loadSpotlight;

// ---- FETCH: Search players ----
async function searchPlayers(query: string) {
	if (query.length < 2) {
		playerResults.innerHTML = '<div class="empty-state">Type at least 2 characters</div>';
		return;
	}

	playerResults.innerHTML = '<div class="loading"><div class="spinner"></div><span>Searching players...</span></div>';

	try {
		const res = await fetch(`/api/players?search=${encodeURIComponent(query)}`);
		const data = await res.json();
		const players = data.players || [];

		if (players.length === 0) {
			playerResults.innerHTML = '<div class="empty-state">No players found</div>';
			return;
		}

		// Mostrar nombres inmediatamente, después cargar stats una por una
		const cards: string[] = players.slice(0, 5).map((p: any) =>
			renderPlayerCard({ ...p, seasonStats: null })
		);
		playerResults.innerHTML = cards.join('');

		// Cargar stats secuencialmente y reemplazar cada card
		for (let i = 0; i < Math.min(players.length, 5); i++) {
			const p = players[i];
			try {
				const statsRes = await fetchRetry(`/api/player-stats/${p.id}`, 2, 1500);
				const statsData = await statsRes.json();
				if (statsData.player) {
					cards[i] = renderPlayerCard(statsData.player);
					playerResults.innerHTML = cards.join('');
				}
			} catch {
				// Card ya está mostrando sin stats, la dejamos así
			}
		}
	} catch {
		playerResults.innerHTML = '<div class="empty-state error">Search failed — try again in a moment</div>';
	}
}

// ---- Search debounce ----
playerSearch.addEventListener('input', () => {
	if (searchTimeout) clearTimeout(searchTimeout);
	searchTimeout = setTimeout(() => {
		searchPlayers(playerSearch.value.trim());
	}, 500);
});

// ---- Init ----
loadGames();
loadSpotlight();
</script>

<!-- Layout del scoreboard -->
<style>
	.scoreboard {
		padding: 1.5vw 4vw;
		height: 90%;
		display: flex;
		flex-direction: column;
		gap: 1.2vw;
		overflow-y: auto;
	}

	.scoreboard::-webkit-scrollbar {
		width: 4px;
	}

	.scoreboard::-webkit-scrollbar-track {
		background: transparent;
	}

	.scoreboard::-webkit-scrollbar-thumb {
		background: var(--cs-scrollbar);
		border-radius: 2px;
	}
</style>

<!-- Estilos globales para HTML dinámico -->
<style is:global>
	/* Game cards */
	.game-card {
		background: var(--cs-card-bg);
		border-radius: 0.7vw;
		padding: 1vw 1.2vw;
		border: 0.5px solid var(--cs-border);
		transition: border-color 0.2s ease, background 0.3s ease;
	}

	.game-card:hover {
		border-color: var(--cs-border-hover);
	}

	.game-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 0.8vw;
	}

	.game-status {
		font-size: 0.65vw;
		color: var(--cs-text-muted);
		letter-spacing: 1.5px;
		font-weight: 500;
	}

	.game-detail {
		font-size: 0.6vw;
		color: var(--cs-text-hint);
	}

	.detail-live {
		color: var(--cs-accent);
		background: var(--cs-accent-bg);
		padding: 0.15vw 0.5vw;
		border-radius: 0.3vw;
		font-weight: 500;
	}

	.game-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.3vw 0;
	}

	.team-info {
		display: flex;
		align-items: center;
		gap: 0.5vw;
	}

	.team-badge {
		width: 2vw;
		height: 2vw;
		min-width: 28px;
		min-height: 28px;
		border-radius: 50%;
		background: var(--cs-badge-bg);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.6vw;
		color: var(--cs-text-secondary);
		font-weight: 500;
		letter-spacing: 0.5px;
		transition: background 0.3s ease;
	}

	.team-name {
		font-size: 0.9vw;
		color: var(--cs-text-primary);
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.score {
		font-size: 1.2vw;
		color: var(--cs-text-secondary);
		font-weight: 500;
	}

	.score-winner {
		color: var(--cs-accent);
	}

	.game-matchup-upcoming {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.5vw;
		padding: 0.5vw 0;
	}

	.team-center {
		text-align: center;
	}

	.team-center .team-badge {
		margin: 0 auto 0.3vw;
	}

	.vs-label {
		font-size: 0.8vw;
		color: var(--cs-text-faint);
		font-weight: 500;
	}

	/* Player cards */
	.player-card {
		background: var(--cs-card-bg);
		border-radius: 0.7vw;
		padding: 1.2vw;
		border: 0.5px solid var(--cs-border);
		margin-bottom: 0.6vw;
		transition: background 0.3s ease, border-color 0.3s ease;
	}

	.player-header {
		display: flex;
		align-items: center;
		gap: 0.8vw;
		margin-bottom: 1vw;
	}

	.player-avatar {
		width: 3vw;
		height: 3vw;
		min-width: 40px;
		min-height: 40px;
		border-radius: 50%;
		background: linear-gradient(135deg, #E8450E, #FF7A3D);
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 500;
		font-size: 0.85vw;
		color: var(--cs-avatar-text);
		flex-shrink: 0;
	}

	.player-name {
		font-size: 1vw;
		color: var(--cs-text-primary);
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.player-meta {
		font-size: 0.7vw;
		color: var(--cs-text-secondary);
		margin-top: 0.15vw;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.5vw;
	}

	.stat-box {
		text-align: center;
		background: var(--cs-stat-bg);
		border-radius: 0.5vw;
		padding: 0.7vw 0.3vw;
		transition: background 0.3s ease;
	}

	.stat-label {
		font-size: 0.6vw;
		color: var(--cs-text-muted);
		margin-bottom: 0.3vw;
		letter-spacing: 0.5px;
	}

	.stat-value {
		font-size: 1.15vw;
		color: var(--cs-text-primary);
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.stat-value.accent {
		color: var(--cs-accent);
	}

	/* Shared states */
	.loading {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6vw;
		padding: 2vw;
		color: var(--cs-text-hint);
		font-size: 0.8vw;
	}

	.spinner {
		width: 1.2vw;
		height: 1.2vw;
		min-width: 16px;
		min-height: 16px;
		border: 2px solid var(--cs-border);
		border-top-color: var(--cs-accent);
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
	}

	@keyframes spin {
		to { transform: rotate(360deg); }
	}

	.empty-state {
		text-align: center;
		padding: 2vw;
		color: var(--cs-text-hint);
		font-size: 0.85vw;
		grid-column: 1 / -1;
	}

	.empty-state.small {
		padding: 1.2vw;
		font-size: 0.75vw;
	}

	.empty-state.error {
		color: var(--cs-error);
	}

	.retry-btn {
		display: inline-block;
		margin-top: 0.5vw;
		padding: 0.3vw 1vw;
		background: var(--cs-accent-bg);
		border: 0.5px solid var(--cs-accent-border);
		border-radius: 0.4vw;
		color: var(--cs-accent);
		font-size: 0.7vw;
		font-weight: 500;
		cursor: pointer;
		font-family: inherit;
		transition: background 0.2s ease;
	}

	.retry-btn:hover {
		background: rgba(232,69,14,0.25);
	}
</style>