---
// ScoreBoard.astro
// Componente orquestador del dashboard NBA.
// Scoreboard: SSR (fetch NBA CDN server-side).
// Players: datos estáticos embebidos (0 API calls).
import TabBar from './TabBar.astro';
import GamesGrid from './GamesGrid.astro';
import PlayerSearch from './PlayerSearch.astro';
import PlayerSpotlight from './PlayerSpotlight.astro';

// ---- Fetch scoreboard server-side ----
let gamesData: any[] = [];
try {
	const controller = new AbortController();
	const timeout = setTimeout(() => controller.abort(), 5000);
	const res = await fetch('https://cdn.nba.com/static/json/liveData/scoreboard/todaysScoreboard_00.json', {
		signal: controller.signal,
		headers: {
			'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
			'Referer': 'https://www.nba.com/',
		}
	});
	clearTimeout(timeout);
	if (res.ok) {
		const data = await res.json();
		gamesData = (data?.scoreboard?.games || []).map((g: any) => ({
			id: g.gameId,
			status: g.gameStatusText?.trim() || '',
			statusCode: g.gameStatus,
			period: g.period,
			clock: g.gameClock?.replace('PT', '').replace('M', ':').replace('S', '') || '',
			homeTeam: {
				id: g.homeTeam?.teamId,
				name: g.homeTeam?.teamName,
				city: g.homeTeam?.teamCity,
				abbr: g.homeTeam?.teamTricode,
				score: g.homeTeam?.score,
			},
			awayTeam: {
				id: g.awayTeam?.teamId,
				name: g.awayTeam?.teamName,
				city: g.awayTeam?.teamCity,
				abbr: g.awayTeam?.teamTricode,
				score: g.awayTeam?.score,
			},
			arena: g.arenaName,
			startTime: g.gameTimeUTC,
		}));
	}
} catch {}
---

<section class="scoreboard">
	<TabBar />
	<GamesGrid />
	<PlayerSearch />
	<PlayerSpotlight />
</section>

<!-- Scoreboard data del server -->
<div id="games-data" data-games={JSON.stringify(gamesData)} style="display:none"></div>

<script>
// ==========================================================
//  COURTSIDE — NBA SCOREBOARD
//  Scoreboard: server-rendered data (NBA CDN)
//  Players: datos estáticos importados (0 API calls)
// ==========================================================

import { searchPlayers as findPlayers, players } from '../data/players';

// ---- DOM refs ----
const tabs = document.querySelectorAll('.tab') as NodeListOf<HTMLButtonElement>;
const tabGames = document.getElementById('tab-games') as HTMLElement;
const tabPlayers = document.getElementById('tab-players') as HTMLElement;
const gamesGrid = document.getElementById('games-grid') as HTMLElement;
const playerSearch = document.getElementById('player-search') as HTMLInputElement;
const playerResults = document.getElementById('player-results') as HTMLElement;
const spotlight = document.getElementById('spotlight') as HTMLElement;
const spotlightCard = document.getElementById('spotlight-card') as HTMLElement;

let searchTimeout: ReturnType<typeof setTimeout> | null = null;

// ---- TABS ----
tabs.forEach(tab => {
	tab.addEventListener('click', () => {
		tabs.forEach(t => t.classList.remove('active'));
		tab.classList.add('active');

		const target = tab.dataset.tab;
		tabGames.classList.toggle('active', target === 'games');
		tabPlayers.classList.toggle('active', target === 'players');
		spotlight.style.display = target === 'games' ? '' : 'none';
	});
});

// ---- RENDER: Game card ----
function renderGameCard(game: any): string {
	const home = game.homeTeam;
	const away = game.awayTeam;
	const statusCode = game.statusCode;

	if (statusCode === 1) {
		const startDate = new Date(game.startTime);
		const timeStr = !isNaN(startDate.getTime())
			? startDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true })
			: game.status || 'TBD';

		return `
		<div class="game-card">
			<div class="game-header">
				<span class="game-status">UPCOMING</span>
				<span class="game-detail">${timeStr}</span>
			</div>
			<div class="game-matchup-upcoming">
				<div class="team-center">
					<div class="team-badge">${away.abbr}</div>
					<span class="team-name">${away.city} ${away.name}</span>
				</div>
				<span class="vs-label">VS</span>
				<div class="team-center">
					<div class="team-badge">${home.abbr}</div>
					<span class="team-name">${home.city} ${home.name}</span>
				</div>
			</div>
		</div>`;
	}

	const isLive = statusCode === 2;
	const isFinal = statusCode === 3;
	const homeWins = isFinal && home.score > away.score;
	const awayWins = isFinal && away.score > home.score;
	const statusLabel = isLive ? 'LIVE' : 'FINAL';

	let detail = '';
	if (isLive) {
		detail = `Q${game.period} ${game.clock}`;
	} else {
		const d = new Date(game.startTime);
		if (!isNaN(d.getTime())) {
			detail = d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
		}
	}

	return `
	<div class="game-card">
		<div class="game-header">
			<span class="game-status">${statusLabel}</span>
			<span class="game-detail ${isLive ? 'detail-live' : ''}">${detail}</span>
		</div>
		<div class="game-row">
			<div class="team-info">
				<div class="team-badge">${away.abbr}</div>
				<span class="team-name">${away.city} ${away.name}</span>
			</div>
			<span class="score ${awayWins ? 'score-winner' : ''}">${away.score}</span>
		</div>
		<div class="game-row">
			<div class="team-info">
				<div class="team-badge">${home.abbr}</div>
				<span class="team-name">${home.city} ${home.name}</span>
			</div>
			<span class="score ${homeWins ? 'score-winner' : ''}">${home.score}</span>
		</div>
	</div>`;
}

// ---- RENDER: Spotlight card (jersey + stats) ----
function renderSpotlightCard(player: any): string {
	const name = `${player.firstName} ${player.lastName}`;
	const team = player.team;
	const number = player.jerseyNumber || '00';
	const position = player.position || '';
	const s = player.stats;

	const statItems = [
		{ label: 'PTS', value: s.pts.toFixed(1), accent: false },
		{ label: 'REB', value: s.reb.toFixed(1), accent: false },
		{ label: 'AST', value: s.ast.toFixed(1), accent: false },
		{ label: 'STL', value: s.stl.toFixed(1), accent: false },
		{ label: 'BLK', value: s.blk.toFixed(1), accent: false },
		{ label: 'FG%', value: (s.fgPct * 100).toFixed(1), accent: true },
	];
	const statsHtml = statItems.map(st =>
		`<div class="sl-stat">
			<div class="sl-stat-value${st.accent ? ' accent' : ''}">${st.value}</div>
			<div class="sl-stat-label">${st.label}</div>
		</div>`
	).join('');

	return `
	<div class="sl-card">
		<div class="sl-jersey-wrap">
			<svg class="sl-jersey" viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg">
				<defs>
					<linearGradient id="jGrad" x1="15" y1="0" x2="145" y2="160" gradientUnits="userSpaceOnUse">
						<stop offset="0%" stop-color="#E8450E"/>
						<stop offset="100%" stop-color="#A12B08"/>
					</linearGradient>
				</defs>
				<path d="M38 10 C50 3,110 3,122 10 L148 35 L134 52 L118 36 L118 152 L42 152 L42 36 L26 52 L12 35 Z"
					fill="url(#jGrad)" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"/>
				<path d="M52 11 L80 30 L108 11" fill="none" stroke="rgba(255,255,255,0.18)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
				<line x1="42" y1="55" x2="118" y2="55" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
				<text x="80" y="112" text-anchor="middle" font-size="44" font-weight="800" fill="rgba(255,255,255,0.85)" font-family="system-ui,sans-serif" letter-spacing="-1">${number}</text>
			</svg>
		</div>
		<div class="sl-info">
			<div class="sl-name">${name}</div>
			<div class="sl-team">${team}${position ? '  |  ' + position : ''}</div>
			<div class="sl-season">${s.season} SEASON AVERAGES  ·  ${s.gp} GP  ·  ${s.min.toFixed(1)} MPG</div>
			<div class="sl-stats">${statsHtml}</div>
		</div>
	</div>`;
}

// ---- RENDER: Player search card ----
function renderSearchCard(player: any): string {
	const initials = `${player.firstName[0]}${player.lastName[0]}`.toUpperCase();
	const name = `${player.firstName} ${player.lastName}`;

	return `
	<div class="player-card">
		<div class="player-header">
			<div class="player-avatar">${initials}</div>
			<div>
				<div class="player-name">${name}</div>
				<div class="player-meta">${player.team}  |  #${player.jerseyNumber}  |  ${player.position}</div>
			</div>
		</div>
		<div class="stats-grid">
			<div class="stat-box"><div class="stat-label">PTS</div><div class="stat-value">${player.stats.pts.toFixed(1)}</div></div>
			<div class="stat-box"><div class="stat-label">REB</div><div class="stat-value">${player.stats.reb.toFixed(1)}</div></div>
			<div class="stat-box"><div class="stat-label">AST</div><div class="stat-value">${player.stats.ast.toFixed(1)}</div></div>
			<div class="stat-box"><div class="stat-label">FG%</div><div class="stat-value accent">${(player.stats.fgPct * 100).toFixed(1)}</div></div>
		</div>
	</div>`;
}

// ---- LOAD: Games (from server-embedded data) ----
function loadGames() {
	const el = document.getElementById('games-data');
	const games = JSON.parse(el?.dataset.games || '[]');

	if (games.length === 0) {
		gamesGrid.innerHTML = '<div class="empty-state">No games scheduled today</div>';
		return;
	}
	gamesGrid.innerHTML = games.map(renderGameCard).join('');
}

// ---- LOAD: Spotlight (random top player, 0 API calls) ----
function loadSpotlight() {
	const topPlayers = players.filter(p => p.stats.pts >= 20);
	const pick = topPlayers[Math.floor(Math.random() * topPlayers.length)];
	spotlightCard.innerHTML = renderSpotlightCard(pick);
}

// ---- SEARCH: Players (instant, 0 API calls) ----
function doSearch(query: string) {
	if (query.length < 2) {
		playerResults.innerHTML = '<div class="empty-state">Type at least 2 characters</div>';
		return;
	}

	const results = findPlayers(query, 10);
	if (results.length === 0) {
		playerResults.innerHTML = '<div class="empty-state">No players found</div>';
		return;
	}

	playerResults.innerHTML = results.map(renderSearchCard).join('');
}

// ---- Search debounce ----
playerSearch.addEventListener('input', () => {
	if (searchTimeout) clearTimeout(searchTimeout);
	searchTimeout = setTimeout(() => {
		doSearch(playerSearch.value.trim());
	}, 200); // 200ms — la búsqueda es instantánea así que no necesita 500ms
});

// ---- Init ----
loadGames();
loadSpotlight();
</script>

<!-- Layout del scoreboard -->
<style>
	.scoreboard {
		padding: 1.5vw 4vw;
		height: 90%;
		display: flex;
		flex-direction: column;
		gap: 1.2vw;
		overflow-y: auto;
	}

	.scoreboard::-webkit-scrollbar {
		width: 4px;
	}

	.scoreboard::-webkit-scrollbar-track {
		background: transparent;
	}

	.scoreboard::-webkit-scrollbar-thumb {
		background: var(--cs-scrollbar);
		border-radius: 2px;
	}
</style>

<!-- Estilos globales para HTML dinámico -->
<style is:global>
	/* Game cards */
	.game-card {
		background: var(--cs-card-bg);
		border-radius: 0.7vw;
		padding: 1vw 1.2vw;
		border: 0.5px solid var(--cs-border);
		transition: border-color 0.2s ease, background 0.3s ease;
	}

	.game-card:hover {
		border-color: var(--cs-border-hover);
	}

	.game-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 0.8vw;
	}

	.game-status {
		font-size: 0.65vw;
		color: var(--cs-text-muted);
		letter-spacing: 1.5px;
		font-weight: 500;
	}

	.game-detail {
		font-size: 0.6vw;
		color: var(--cs-text-hint);
	}

	.detail-live {
		color: var(--cs-accent);
		background: var(--cs-accent-bg);
		padding: 0.15vw 0.5vw;
		border-radius: 0.3vw;
		font-weight: 500;
	}

	.game-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.3vw 0;
	}

	.team-info {
		display: flex;
		align-items: center;
		gap: 0.5vw;
	}

	.team-badge {
		width: 2vw;
		height: 2vw;
		min-width: 28px;
		min-height: 28px;
		border-radius: 50%;
		background: var(--cs-badge-bg);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.6vw;
		color: var(--cs-text-secondary);
		font-weight: 500;
		letter-spacing: 0.5px;
		transition: background 0.3s ease;
	}

	.team-name {
		font-size: 0.9vw;
		color: var(--cs-text-primary);
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.score {
		font-size: 1.2vw;
		color: var(--cs-text-secondary);
		font-weight: 500;
	}

	.score-winner {
		color: var(--cs-accent);
	}

	.game-matchup-upcoming {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.5vw;
		padding: 0.5vw 0;
	}

	.team-center {
		text-align: center;
	}

	.team-center .team-badge {
		margin: 0 auto 0.3vw;
	}

	.vs-label {
		font-size: 0.8vw;
		color: var(--cs-text-faint);
		font-weight: 500;
	}

	/* Player cards */
	.player-card {
		background: var(--cs-card-bg);
		border-radius: 0.7vw;
		padding: 1.2vw;
		border: 0.5px solid var(--cs-border);
		margin-bottom: 0.6vw;
		transition: background 0.3s ease, border-color 0.3s ease;
	}

	.player-header {
		display: flex;
		align-items: center;
		gap: 0.8vw;
		margin-bottom: 1vw;
	}

	.player-avatar {
		width: 3vw;
		height: 3vw;
		min-width: 40px;
		min-height: 40px;
		border-radius: 50%;
		background: linear-gradient(135deg, #E8450E, #FF7A3D);
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 500;
		font-size: 0.85vw;
		color: var(--cs-avatar-text);
		flex-shrink: 0;
	}

	.player-name {
		font-size: 1vw;
		color: var(--cs-text-primary);
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.player-meta {
		font-size: 0.7vw;
		color: var(--cs-text-secondary);
		margin-top: 0.15vw;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.5vw;
	}

	.stat-box {
		text-align: center;
		background: var(--cs-stat-bg);
		border-radius: 0.5vw;
		padding: 0.7vw 0.3vw;
		transition: background 0.3s ease;
	}

	.stat-label {
		font-size: 0.6vw;
		color: var(--cs-text-muted);
		margin-bottom: 0.3vw;
		letter-spacing: 0.5px;
	}

	.stat-value {
		font-size: 1.15vw;
		color: var(--cs-text-primary);
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.stat-value.accent {
		color: var(--cs-accent);
	}

	/* Shared states */
	.empty-state {
		text-align: center;
		padding: 2vw;
		color: var(--cs-text-hint);
		font-size: 0.85vw;
		grid-column: 1 / -1;
	}

	.empty-state.error {
		color: var(--cs-error);
	}

	/* Spotlight card */
	.sl-card {
		display: flex;
		align-items: center;
		gap: 2.5vw;
		background: var(--cs-card-bg);
		border: 0.5px solid var(--cs-border);
		border-radius: 0.7vw;
		padding: 2vw 3vw;
		transition: background 0.3s ease, border-color 0.3s ease;
	}

	.sl-card:hover {
		border-color: var(--cs-border-hover);
	}

	.sl-jersey-wrap {
		flex-shrink: 0;
		filter: drop-shadow(0 4px 20px rgba(232, 69, 14, 0.25));
	}

	.sl-jersey {
		width: 10vw;
		min-width: 120px;
		max-width: 180px;
		aspect-ratio: 1;
	}

	.sl-info {
		flex: 1;
		min-width: 0;
	}

	.sl-name {
		font-size: 1.6vw;
		font-weight: 600;
		color: var(--cs-text-primary);
		transition: color 0.3s ease;
		margin-bottom: 0.2vw;
	}

	.sl-team {
		font-size: 0.8vw;
		color: var(--cs-text-secondary);
		margin-bottom: 0.8vw;
	}

	.sl-season {
		font-size: 0.6vw;
		color: var(--cs-text-muted);
		letter-spacing: 1px;
		margin-bottom: 0.8vw;
		font-weight: 500;
	}

	.sl-stats {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 0.5vw;
	}

	.sl-stat {
		text-align: center;
		background: var(--cs-stat-bg);
		border-radius: 0.5vw;
		padding: 0.6vw 0.3vw;
		transition: background 0.3s ease;
	}

	.sl-stat-value {
		font-size: 1.2vw;
		font-weight: 600;
		color: var(--cs-text-primary);
		transition: color 0.3s ease;
	}

	.sl-stat-value.accent {
		color: var(--cs-accent);
	}

	.sl-stat-label {
		font-size: 0.55vw;
		color: var(--cs-text-muted);
		letter-spacing: 0.5px;
		margin-top: 0.2vw;
	}
</style>
