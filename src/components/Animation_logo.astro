---
// Componente de animación de la pelota de basketball.
// Requiere que el contenido de la página esté dentro de un <div id="page-content">.
// Requiere que exista un elemento .courtside-logo dentro de page-content como destino.
---

<div id="ball-animation" aria-hidden="true">
	<svg id="ball-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
		<defs>
			<linearGradient id="animBallGrad" x1="0%" y1="0%" x2="100%" y2="100%">
				<stop offset="0%" stop-color="#FF7A3D"/>
				<stop offset="100%" stop-color="#E8450E"/>
			</linearGradient>
		</defs>
		<circle cx="32" cy="32" r="28" fill="url(#animBallGrad)"/>
		<path d="M32 4 L32 60" stroke="#1A1A2E" stroke-width="2.4" stroke-linecap="round" opacity="0.45"/>
		<path d="M4 32 L60 32" stroke="#1A1A2E" stroke-width="2.4" stroke-linecap="round" opacity="0.45"/>
		<path d="M7 14 C20 21, 44 21, 57 14" stroke="#1A1A2E" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.35"/>
		<path d="M7 50 C20 43, 44 43, 57 50" stroke="#1A1A2E" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.35"/>
		<ellipse cx="22" cy="21" rx="8" ry="5" fill="white" opacity="0.18" transform="rotate(-25 22 21)"/>
	</svg>
</div>

<script>

//  ANIMACIÓN — PELOTA CON TRAYECTORIA BÉZIER CÚBICA


const ball = document.getElementById('ball-animation') as HTMLElement;
const ballSvg = document.getElementById('ball-svg') as HTMLElement;
const pageContent = document.getElementById('page-content') as HTMLElement;
const logoEl = pageContent?.querySelector('.courtside-logo') as HTMLElement;

if (ball && ballSvg && pageContent && logoEl) {

	// ---- CONFIG ----
	const INITIAL_SIZE    = 780;    // px — bien grande, "en tu cara"
	const FLIGHT_DURATION = 1200;   // ms — duración del vuelo
	const SPIN_DEGREES    = -720;   // rotación total (2 vueltas exactas → termina en 0°)

	// ---- POSICIONES ----
	const vw = window.innerWidth;
	const vh = window.innerHeight;

	// Inicio: centro de pantalla
	const P0 = { x: vw * 0.50, y: vh * 0.50 };

	// Final: centro del logo en el header
	const logoRect = logoEl.getBoundingClientRect();
	const P3 = {
		x: logoRect.left + logoRect.width / 2,
		y: logoRect.top + logoRect.height / 2
	};

	// Tamaño final = tamaño real del SVG dentro del logo
	const logoSvg = logoEl.querySelector('svg');
	const finalSize = logoSvg
		? Math.max(logoSvg.getBoundingClientRect().width, logoSvg.getBoundingClientRect().height)
		: Math.max(logoRect.width, logoRect.height);

	// Puntos de control para la curva Bézier cúbica:
	// La pelota arranca al centro, se va hacia la IZQUIERDA
	// y abajo, recorre el lado izquierdo, y sube en curva
	// hasta llegar al logo en el header.
	const P1 = { x: vw * 0.06, y: vh * 0.65 };
	const P2 = { x: vw * 0.04, y: vh * 0.08 };

	// ESTADO INICIAL DE LA PELOTA 
	ball.style.transform = `translate(${P0.x - INITIAL_SIZE / 2}px, ${P0.y - INITIAL_SIZE / 2}px)`;
	ballSvg.style.width = `${INITIAL_SIZE}px`;
	ballSvg.style.height = `${INITIAL_SIZE}px`;
	ball.style.opacity = '1';

		// ================================
	//  CURVA BÉZIER CÚBICA — B(t)
	// ================================
	function cubicBezier(t: number, p0: number, p1: number, p2: number, p3: number): number {
		const mt = 1 - t;
		return mt * mt * mt * p0
			+ 3 * mt * mt * t * p1
			+ 3 * mt * t * t * p2
			+ t * t * t * p3;
	}

	function easeOutQuart(t: number): number {
		return 1 - Math.pow(1 - t, 4);
	}

	// ================================
	//  LOOP DE ANIMACIÓN
	// ================================
	let startTime: number | null = null;

	function animateFrame(timestamp: number) {
		if (!startTime) startTime = timestamp;

		const elapsed = timestamp - startTime;
		const rawT = Math.min(elapsed / FLIGHT_DURATION, 1);
		const t = easeOutQuart(rawT);

		const currentX = cubicBezier(t, P0.x, P1.x, P2.x, P3.x);
		const currentY = cubicBezier(t, P0.y, P1.y, P2.y, P3.y);

		const currentSize = INITIAL_SIZE + (finalSize - INITIAL_SIZE) * t;
		const rotation = SPIN_DEGREES * t;

		const shadowOpacity = (0.6 * Math.max(0, 1 - t * 1.1)).toFixed(2);
		const shadowBlur    = (14 * Math.max(0, 1 - t * 1.1)).toFixed(1);

		ball.style.transform = `translate(${currentX - currentSize / 2}px, ${currentY - currentSize / 2}px)`;
		ballSvg.style.width  = `${currentSize}px`;
		ballSvg.style.height = `${currentSize}px`;
		ballSvg.style.transform = `rotate(${rotation}deg)`;
		ballSvg.style.filter = `drop-shadow(0 4px ${shadowBlur}px rgba(232, 69, 14, ${shadowOpacity}))`;

		if (rawT < 1) {
			requestAnimationFrame(animateFrame);
		} else {
			ballSvg.style.transform = 'rotate(0deg)';
			ballSvg.style.filter = 'none';

			ball.animate(
				[{ opacity: 1 }, { opacity: 0 }],
				{ duration: 150, fill: 'forwards', easing: 'ease-in' }
			).onfinish = () => {
				ball.style.display = 'none';
			};

			pageContent.style.opacity = '1';
		}
	}

	requestAnimationFrame(animateFrame);

} else {
	const pc = document.getElementById('page-content');
	const ba = document.getElementById('ball-animation');
	if (pc) pc.style.opacity = '1';
	if (ba) ba.style.display = 'none';
}
</script>

<style is:global>
	#ball-animation {
		position: fixed;
		top: 0;
		left: 0;
		z-index: 999;
		pointer-events: none;
		will-change: transform;
	}

	#ball-svg {
		display: block;
		will-change: transform, width, height, filter;
	}

	#page-content {
		opacity: 0;
		transition: opacity 450ms ease;
	}
</style>