---
// Componente de animación de la pelota de basketball.
// Requiere que el contenido de la página esté dentro de un <div id="page-content">.
// Requiere que exista un elemento .courtside-logo dentro de page-content como destino.
---

<div id="ball-animation" aria-hidden="true">
	<svg id="ball-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
		<defs>
			<linearGradient id="animBallGrad" x1="0%" y1="0%" x2="100%" y2="100%">
				<stop offset="0%" stop-color="#FF7A3D"/>
				<stop offset="100%" stop-color="#E8450E"/>
			</linearGradient>
		</defs>
		<circle cx="32" cy="32" r="28" fill="url(#animBallGrad)"/>
		<path d="M32 4 L32 60" stroke="#1A1A2E" stroke-width="2.4" stroke-linecap="round" opacity="0.45"/>
		<path d="M4 32 L60 32" stroke="#1A1A2E" stroke-width="2.4" stroke-linecap="round" opacity="0.45"/>
		<path d="M7 14 C20 21, 44 21, 57 14" stroke="#1A1A2E" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.35"/>
		<path d="M7 50 C20 43, 44 43, 57 50" stroke="#1A1A2E" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.35"/>
		<ellipse cx="22" cy="21" rx="8" ry="5" fill="white" opacity="0.18" transform="rotate(-25 22 21)"/>
	</svg>
</div>

<script>
import gsap from 'gsap';

// ANIMACIÓN — PELOTA CON TRAYECTORIA BÉZIER CÚBICA (GSAP)

const ball = document.getElementById('ball-animation') as HTMLElement;
const ballSvg = document.getElementById('ball-svg') as HTMLElement;
const pageContent = document.getElementById('page-content') as HTMLElement;
const logoEl = pageContent?.querySelector('.courtside-logo') as HTMLElement;

if (ball && ballSvg && pageContent && logoEl) {

	// ---- CONFIG ----
	const INITIAL_SIZE = 780;
	const SPIN_DEGREES = -720;

	// ---- POSICIONES ----
	const vw = window.innerWidth;
	const vh = window.innerHeight;

	const P0 = { x: vw * 0.50, y: vh * 0.50 };

	const logoRect = logoEl.getBoundingClientRect();
	const P3 = { x: logoRect.left + logoRect.width / 2, y: logoRect.top + logoRect.height / 2 };

	const logoSvg = logoEl.querySelector('svg');
	const finalSize = logoSvg
		? Math.max(logoSvg.getBoundingClientRect().width, logoSvg.getBoundingClientRect().height)
		: Math.max(logoRect.width, logoRect.height);

	// Puntos de control Bézier: centro → izquierda-abajo → izquierda-arriba → logo
	const P1 = { x: vw * 0.06, y: vh * 0.65 };
	const P2 = { x: vw * 0.04, y: vh * 0.08 };

	// ---- BÉZIER CÚBICA ----
	function bezier(t: number, p0: number, p1: number, p2: number, p3: number): number {
		const mt = 1 - t;
		return mt * mt * mt * p0 + 3 * mt * mt * t * p1 + 3 * mt * t * t * p2 + t * t * t * p3;
	}

	// ---- ESTADO INICIAL ----
	gsap.set(ball, { x: P0.x - INITIAL_SIZE / 2, y: P0.y - INITIAL_SIZE / 2, opacity: 1 });
	gsap.set(ballSvg, { width: INITIAL_SIZE, height: INITIAL_SIZE });

	// ---- TIMELINE ----
	const progress = { t: 0 };

	gsap.timeline()
		// Vuelo Bézier: 1.2s con easeOutQuart
		.to(progress, {
			t: 1,
			duration: 1.2,
			ease: 'power4.out',
			onUpdate() {
				const { t } = progress;
				const x = bezier(t, P0.x, P1.x, P2.x, P3.x);
				const y = bezier(t, P0.y, P1.y, P2.y, P3.y);
				const size = INITIAL_SIZE + (finalSize - INITIAL_SIZE) * t;
				const shadowFade = Math.max(0, 1 - t * 1.1);

				gsap.set(ball, { x: x - size / 2, y: y - size / 2 });
				gsap.set(ballSvg, {
					width: size,
					height: size,
					rotation: SPIN_DEGREES * t,
					filter: `drop-shadow(0 4px ${(14 * shadowFade).toFixed(1)}px rgba(232,69,14,${(0.6 * shadowFade).toFixed(2)}))`,
				});
			},
		})
		// Reset rotación + limpiar sombra
		.set(ballSvg, { rotation: 0, filter: 'none' })
		// Fade out pelota + fade in contenido (simultáneos)
		.to(ball, {
			opacity: 0,
			duration: 0.15,
			ease: 'power1.in',
			onComplete: () => { ball.style.display = 'none'; },
		})
		.to(pageContent, { opacity: 1, duration: 0.45 }, '<');

} else {
	const pc = document.getElementById('page-content');
	const ba = document.getElementById('ball-animation');
	if (pc) pc.style.opacity = '1';
	if (ba) ba.style.display = 'none';
}
</script>

<style is:global>
	#ball-animation {
		position: fixed;
		top: 0;
		left: 0;
		z-index: 999;
		pointer-events: none;
		will-change: transform;
	}

	#ball-svg {
		display: block;
		will-change: transform, width, height, filter;
	}

	#page-content {
		opacity: 0;
	}
</style>
