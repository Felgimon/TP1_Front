---
// ApiKeyBar.astro — Barra de configuración del API key
---

<div class="api-config" id="api-config">
	<div class="api-config-inner">
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;flex-shrink:0;opacity:0.5;">
			<path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/>
		</svg>
		<input
			type="text"
			id="api-key-input"
			placeholder="balldontlie.io API key"
		/>
		<button id="api-key-save">Connect</button>
	</div>
	<p class="api-hint">
		Free key at <a href="https://app.balldontlie.io" target="_blank" rel="noopener">app.balldontlie.io</a>
	</p>
</div>

<style>
	.api-config {
		margin-top: auto;
		padding-top: 1vw;
		border-top: 0.5px solid rgba(255,255,255,0.06);
		flex-shrink: 0;
	}

	.api-config-inner {
		display: flex;
		align-items: center;
		gap: 0.5vw;
		background: rgba(255,255,255,0.03);
		border-radius: 0.5vw;
		padding: 0.4vw 0.8vw;
		border: 0.5px solid rgba(255,255,255,0.06);
	}

	.api-config-inner input {
		flex: 1;
		background: none;
		border: none;
		color: #F0F0F0;
		font-size: 0.75vw;
		font-family: var(--font-mono, monospace);
		outline: none;
		padding: 0.3vw 0;
	}

	.api-config-inner input::placeholder {
		color: rgba(240,240,240,0.2);
	}

	.api-config-inner button {
		padding: 0.3vw 0.8vw;
		background: rgba(232,69,14,0.15);
		border: 0.5px solid rgba(232,69,14,0.3);
		border-radius: 0.4vw;
		color: #E8450E;
		font-size: 0.7vw;
		font-weight: 500;
		cursor: pointer;
		font-family: inherit;
		transition: all 0.2s ease;
		white-space: nowrap;
	}

	.api-config-inner button:hover {
		background: rgba(232,69,14,0.25);
	}

	.api-config-inner button.connected {
		color: rgba(240,240,240,0.4);
		background: rgba(255,255,255,0.04);
		border-color: rgba(255,255,255,0.08);
	}

	.api-hint {
		font-size: 0.6vw;
		color: rgba(240,240,240,0.2);
		margin-top: 0.4vw;
		text-align: right;
	}

	.api-hint a {
		color: rgba(232,69,14,0.6);
		text-decoration: none;
	}

	.api-hint a:hover {
		color: #E8450E;
	}
</style>
