---
// PlayerSpotlight.astro — Jugador destacado del día
---

<div class="spotlight" id="spotlight">
	<div class="section-label">PLAYER SPOTLIGHT</div>
	<div id="spotlight-card" class="loading-placeholder">
		<div class="spinner"></div>
		<span>Loading player...</span>
	</div>
</div>

<style>
	.spotlight {
		flex: 1;
		min-height: 0;
	}

	.section-label {
		font-size: 0.65vw;
		color: var(--cs-text-muted);
		letter-spacing: 1.5px;
		margin-bottom: 0.8vw;
		font-weight: 500;
	}

	.loading-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6vw;
		padding: 2vw;
		color: var(--cs-text-hint);
		font-size: 0.8vw;
	}
</style>
