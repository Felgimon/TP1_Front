---
import Logo from '../components/Logo.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
---

<nav class="Header">
    <Logo variant="icon" width="3.5vw" />
    <div class="Header-text">
        <h1>
            <span class="text-title">COURT </span>
            <span class="text-gradient">SIDE</span>
        </h1>
        <h3><span class="nba-underline">NBA</span> TRACKER</h3>
    </div>
    <ThemeToggle />
</nav>

<style>
    .Header {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
        height: 10%;
        gap: 0.35vw;
        width: 100%;
        position: relative;
    }

    .text-title {
        color: var(--cs-text-primary);
        transition: color 0.3s ease;
    }

    h1 {
        font-weight: 900;
        letter-spacing: 0.2vw;
    }

    h3 {
        font-weight: 400;
        letter-spacing: 0.3vw;
        font-size: 0.8vw;
        color: var(--cs-text-secondary);
        transition: color 0.3s ease;
    }

    .text-gradient {
        background: linear-gradient(90deg, #e85d04, #f48c06);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .nba-underline {
        border-bottom: 0.15vw solid var(--cs-accent);
        padding-bottom: 0.15vw;
    }
    
    .Header-text {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
</style>
