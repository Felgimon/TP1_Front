---
//http://localhost:4321
import Header from '../components/Header.astro';
import AnimationLogo from '../components/Animation_logo.astro';
import ScoreBoard from '../components/ScoreBoard.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="src/assets/courtside-icon.svg" />
		<link rel="icon" href="src/assets/courtside-icon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Court Side</title>
	</head>
	<body>
		<AnimationLogo />

		<div id="page-content">
			<Header />
			<ScoreBoard />
		</div>
	</body>
</html>

<style is:global>
	* {
		margin: 0;
		margin-block: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		width: 100vw;
		height: 100vh;
		background-color: #1A1A2E;
		font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
		overflow: hidden;
	}

	#page-content {
		width: 100%;
		height: 100%;
	}
</style>